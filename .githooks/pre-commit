#!/bin/bash
# Pre-commit hook — portfolio session hygiene
#
# Enforces (blockers):
#   - TypeScript clean (tsc --noEmit)
#
# Reminds (warnings — docs are gitignored, discipline is manual):
#   - Update docs/CHANGELOG.md if app code staged
#   - Update docs/plans/IMPROVEMENT_PIPELINE.md on significant commits
#   - Update docs/specs/CONTENT_AUDIT.md if canonical.ts changed
#   - CLAUDE.md §11 metrics if canonical.ts changed
#
# Escape hatch: SKIP_CHECKS=1 git commit ...  (use sparingly, WIP only)
#
# Design note: docs/ and CLAUDE.md are in .gitignore (private docs pattern),
# so hook cannot *enforce* doc updates via staging. Hook reminds; user
# maintains discipline. Committed scaffolding (the hooks + scripts) encodes
# the ritual so future sessions have the reminder in front of them.

set -e

if [ "$SKIP_CHECKS" = "1" ]; then
  echo "⚠️  SKIP_CHECKS=1 — bypassing pre-commit validation"
  exit 0
fi

echo "━━━ pre-commit: session hygiene ━━━"

STAGED=$(git diff --cached --name-only)

# 1. TypeScript check — blocker (fast, ~2-5s on this project)
if echo "$STAGED" | grep -qE '\.(ts|tsx)$'; then
  echo "→ tsc --noEmit"
  if ! npx tsc --noEmit 2>&1 | tail -20; then
    echo "✗ TypeScript errors. Fix before committing, or SKIP_CHECKS=1 for WIP."
    exit 1
  fi
  echo "  ✓ tsc clean"
fi

# 2. Doc-discipline reminders (docs are gitignored; checks are informational)
REMINDERS=""

if echo "$STAGED" | grep -qE '^(app|components|data|lib)/'; then
  REMINDERS="$REMINDERS
  📝 App code staged. Confirm:
     - docs/CHANGELOG.md has this session's entry (locally; not tracked)
     - docs/plans/IMPROVEMENT_PIPELINE.md tier status reflects reality
     - docs/specs/DECISIONS.md updated if architectural choice made
     - docs/specs/CONTENT_AUDIT.md updated if claim reconciled"
fi

if echo "$STAGED" | grep -q '^data/canonical\.ts$'; then
  REMINDERS="$REMINDERS
  📐 data/canonical.ts staged. Confirm:
     - CLAUDE.md §11 metrics table matches (locally; not tracked)
     - Downstream consumers (metrics.ts, projects.ts, timeline.ts, hero.ts) are consistent"
fi

CHANGED_LINES=$(git diff --cached --numstat | awk '{s+=$1+$2} END {print s+0}')
if [ "$CHANGED_LINES" -gt 100 ]; then
  REMINDERS="$REMINDERS
  📊 Large change (~$CHANGED_LINES line-changes). Confirm:
     - IMPROVEMENT_PIPELINE.md tier advanced / completed / scope-changed
     - CHANGELOG has a full narrative entry, not just a bullet"
fi

if [ -n "$REMINDERS" ]; then
  echo "$REMINDERS"
  echo ""
fi

echo "━━━ ✓ pre-commit passed ━━━"
